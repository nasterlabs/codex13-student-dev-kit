root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{ps1,psm1,psd1,cmd,bat,nsi,nsh,rc}]
end_of_line = crlf

[*.rc]
indent_style = unset
indent_size = unset

[*.rtf]
end_of_line = crlf
trim_trailing_whitespace = false

[*.{md,mdc,txt}]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = false

[**/{LICENSE,NOTICE}]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = false

[LICENSES/**]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = false

[.reuse/dep5]
indent_style = unset
indent_size = unset

[*.{cpp,c,h,hpp,php}]
indent_size = 2

[*.{json,yml,yaml,cjs}]
indent_size = 2

[*.{vcxproj,props,targets,xml,recipe}]
indent_size = 2
