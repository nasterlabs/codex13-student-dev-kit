NSIS_PATH=C:\Tools\nsis\makensis.exe

# Local env files contain machine-specific paths and secrets.
# Never commit .env.dev. Commit only this template.

BUILD_CHANNEL=dev

# BUILD_VERSION is optional. If overridden, keep the same SemVer core as
# APP_VERSION in apps/setup/src/nsis/config.nsh. First public builds use
# 0.7.0-alpha.<build_number>.
# BUILD_VERSION=0.7.0-alpha.local

# Debug log written next to the installer EXE during a run.
C13_DEBUG_LOG_ENABLED=1
# C13_DEBUG_LOG_FILE=$EXEDIR\c13sdk-debug.log

# Optional local dev signing.
# Run tools\dev\setup-dev-cert.ps1 to generate and trust a local dev certificate,
# then use the generated certificate thumbprint in .env.dev.
SIGNING_ENABLED=0
# SIGN_CERT_THUMBPRINT=
# SIGN_TIMESTAMP_URL=http://timestamp.digicert.com
