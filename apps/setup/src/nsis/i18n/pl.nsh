; Codex 13 Student Dev Kit — Polish UI strings.
; Included by Codex13StudentDevKit.nsi.
; spell-checker: disable

LangString C13_WELCOME_TITLE ${LANG_POLISH} "Witaj w Codex 13 Student Dev Kit Setup"
LangString C13_WELCOME_TEXT ${LANG_POLISH} "Ten kreator przygotuje przenośne środowisko developerskie Codex 13 na tym komputerze.$\r$\n$\r$\nŚrodowisko może zawierać edytor kodu, Git, lokalny serwer web, narzędzia pomocnicze oraz skróty startowe. Instalacja nie wymaga uprawnień administratora, jeśli wybierzesz katalog z prawem zapisu.$\r$\n$\r$\nKliknij Dalej, aby rozpocząć."
LangString C13_FINISH_TITLE ${LANG_POLISH} "Środowisko gotowe"
LangString C13_FINISH_TEXT ${LANG_POLISH} "Codex 13 Student Dev Kit został przygotowany.$\r$\n$\r$\nMożesz teraz otworzyć stronę Codex 13, otworzyć katalog instalacji albo zakończyć kreator.$\r$\n$\r$\nZainstalowane komponenty, licencje i manifest znajdziesz w katalogu instalacji."
LangString C13_FINISH_RUN ${LANG_POLISH} "Otwórz Codex 13"
LangString C13_FINISH_OPEN_INSTALL_DIR ${LANG_POLISH} "Otwórz katalog instalacji"
LangString C13_SHORTCUT_OPEN_INSTALL_DIR ${LANG_POLISH} "Otwórz katalog instalacji Codex 13 Student Dev Kit"
LangString C13_SHORTCUT_UNINSTALL ${LANG_POLISH} "Odinstaluj Codex 13 Student Dev Kit"
LangString C13_SHORTCUT_OPEN_SITE ${LANG_POLISH} "Otwórz stronę Codex 13"
LangString C13_DIRECTORY_TEXT_TOP ${LANG_POLISH} "Wybierz katalog, w którym powstanie przenośne środowisko Codex 13 Student Dev Kit.$\r$\n$\r$\nZalecane lokalizacje: katalog użytkownika w AppData\Local, osobny katalog roboczy albo inny katalog z prawem zapisu. Nie zaleca się Program Files ani katalogów systemowych, jeśli środowisko ma działać bez uprawnień administratora.$\r$\n$\r$\nCache pobranych archiwów: packages w katalogu instalacji."

LangString C13_TERMS_TITLE ${LANG_POLISH} "Warunki i prywatność"
LangString C13_TERMS_SUBTITLE ${LANG_POLISH} "Przeczytaj krótkie podsumowanie i potwierdź wymagane zgody."
LangString C13_TERMS_ACCEPT_LICENSE ${LANG_POLISH} "Akceptuję warunki licencji Codex 13 Student Dev Kit."
LangString C13_TERMS_ACCEPT_EXTERNAL ${LANG_POLISH} "Rozumiem, że instalator może pobierać i konfigurować narzędzia zewnętrzne."
LangString C13_TERMS_ACCEPT_PRIVACY ${LANG_POLISH} "Zapoznałem/am się z informacją o prywatności i lokalnych logach diagnostycznych."

LangString C13_PROFILE_TITLE ${LANG_POLISH} "Wybierz profil środowiska"
LangString C13_PROFILE_SUBTITLE ${LANG_POLISH} "Profil opisuje scenariusz użycia i dobiera zestaw komponentów."
LangString C13_PROFILE_INTRO ${LANG_POLISH} "Profil odpowiada na pytanie: do czego ma służyć środowisko?"
LangString C13_PROFILE_START_DESC ${LANG_POLISH} "Nauka, notatki, Markdown i proste projekty."
LangString C13_PROFILE_WEB_DESC ${LANG_POLISH} "Aplikacje webowe JS/TS."
LangString C13_PROFILE_FULLSTACK_DESC ${LANG_POLISH} "PHP/MySQL, XAMPP i stacki mieszane. Dobry profil domyślny."
LangString C13_PROFILE_CLASSROOM_DESC ${LANG_POLISH} "Zajęcia, kursy i pracownie."
LangString C13_PROFILE_CUSTOM_DESC ${LANG_POLISH} "Ręczny wybór komponentów i ustawień instalacji."
LangString C13_PLANNED ${LANG_POLISH} "(planowane) "

LangString C13_PRESET_TITLE ${LANG_POLISH} "Wybierz preset konfiguracji"
LangString C13_PRESET_SUBTITLE ${LANG_POLISH} "Preset określa ustawienia startowe, launchery i konfigurację VS Code."
LangString C13_SELECTED_PROFILE ${LANG_POLISH} "Wybrany profil:"
LangString C13_PRESET_CLEAN_VSCODE ${LANG_POLISH} "Czysty VS Code"
LangString C13_PRESET_CLEAN_VSCODE_DESC ${LANG_POLISH} "Tylko Visual Studio Code portable oraz elementy bazowe Setupu."
LangString C13_PRESET_BASIC_DESC ${LANG_POLISH} "Minimalna konfiguracja do notatek, Markdown i lekkich projektów."
LangString C13_PRESET_MARKDOWN_DESC ${LANG_POLISH} "Ustawienia pod Markdown, pliki tekstowe i organizację notatek."
LangString C13_PRESET_FRONTEND_DESC ${LANG_POLISH} "Konfiguracja pod HTML, CSS, JavaScript, TypeScript, React i Vite."
LangString C13_PRESET_BACKEND_DESC ${LANG_POLISH} "Konfiguracja pod Node.js, npm/pnpm, API i projekty backendowe."
LangString C13_PRESET_STATIC_DESC ${LANG_POLISH} "Konfiguracja pod statyczne strony i proste projekty frontendowe."
LangString C13_PRESET_PHP_MYSQL_DESC ${LANG_POLISH} "Konfiguracja pod XAMPP, Apache, PHP i MySQL."
LangString C13_PRESET_NODE_API_DESC ${LANG_POLISH} "Konfiguracja pod Node.js, API i backend JavaScript/TypeScript."
LangString C13_PRESET_MIXED_DESC ${LANG_POLISH} "Konfiguracja pod projekty łączące Node.js oraz XAMPP."
LangString C13_PRESET_INF03_DESC ${LANG_POLISH} "Konfiguracja do zajęć z podstaw aplikacji webowych."
LangString C13_PRESET_CLASSROOM_PHP_DESC ${LANG_POLISH} "Konfiguracja do zajęć z PHP, formularzy, baz danych i XAMPP."
LangString C13_PRESET_CLASSROOM_NODE_DESC ${LANG_POLISH} "Konfiguracja do zajęć z backendu Node.js/API."
LangString C13_PRESET_MANUAL_DESC ${LANG_POLISH} "Ręczna konfiguracja komponentów."
LangString C13_PRESET_LAUNCHER_INFO ${LANG_POLISH} "Informacja: VS Code zostanie uruchamiany przez launcher Codex 13, który automatycznie doda do PATH narzędzia zainstalowane w tym środowisku."
LangString C13_PRESET_PLANNED_CLEAN ${LANG_POLISH} "Ten preset jest jeszcze planowany.$\r$\nSetup wróci do aktywnego presetu: Czysty VS Code."
LangString C13_PRESET_PLANNED_PHP ${LANG_POLISH} "Ten preset jest jeszcze planowany.$\r$\nSetup wróci do aktywnego presetu: PHP + MySQL."

LangString C13_COMPONENTS_TITLE ${LANG_POLISH} "Wybierz komponenty"
LangString C13_COMPONENTS_SUBTITLE ${LANG_POLISH} "Profil i preset ustawiły domyślny zestaw komponentów. Możesz go dostosować przed instalacją."
LangString C13_COMPONENTS_START_MENU_AUTO ${LANG_POLISH} "Folder w Menu Start zostanie utworzony automatycznie."
LangString C13_COMPONENTS_REQUIRED ${LANG_POLISH} "Wymagane"
LangString C13_COMPONENTS_LEGAL ${LANG_POLISH} "✓ Pliki prawne, manifest i logi"
LangString C13_COMPONENTS_TOOLS ${LANG_POLISH} "Narzędzia"
LangString C13_COMPONENTS_RUNTIME ${LANG_POLISH} "Serwery i runtime"
LangString C13_COMPONENTS_NODE_PLANNED ${LANG_POLISH} "Node.js portable będzie dostępny w kolejnej wersji."
LangString C13_COMPONENTS_DESCRIPTION ${LANG_POLISH} "Opis komponentu"
LangString C13_COMPONENTS_DESKTOP ${LANG_POLISH} "Skróty na pulpicie"
LangString C13_COMPONENTS_NO_MAIN_TOOLS ${LANG_POLISH} "Odznaczono wszystkie główne narzędzia.$\r$\n$\r$\nSetup utworzy tylko strukturę bazową, launchery, pliki prawne, manifest i logi. Kontynuować?"
LangString C13_COMPONENTS_NO_GIT ${LANG_POLISH} "Git for Windows jest ważny dla większości scenariuszy Codex 13.$\r$\n$\r$\nMożesz kontynuować bez Git, ale część workflow może wymagać ręcznej konfiguracji. Kontynuować?"

LangString C13_DIR_PROGRAM_FILES_WARNING ${LANG_POLISH} "Wybrany katalog znajduje się w Program Files.$\r$\n$\r$\nŚrodowisko portable może wymagać wtedy uprawnień administratora do zapisu. Możesz kontynuować świadomie albo wrócić i wybrać katalog użytkownika."
LangString C13_DIR_WINDOWS_WARNING ${LANG_POLISH} "Wybrany katalog znajduje się w katalogu systemowym Windows.$\r$\n$\r$\nNie jest to zalecane dla środowiska portable. Możesz kontynuować świadomie albo wrócić i wybrać katalog użytkownika."
LangString C13_DIR_CREATE_FAILED ${LANG_POLISH} "Nie można utworzyć katalogu instalacji:$\r$\n$INSTDIR$\r$\n$\r$\nWybierz katalog, do którego masz prawo zapisu."

