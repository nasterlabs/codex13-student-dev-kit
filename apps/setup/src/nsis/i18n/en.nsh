LangString C13_EXISTING_TITLE ${LANG_ENGLISH} "Existing Installation"
LangString C13_EXISTING_SUBTITLE ${LANG_ENGLISH} "Choose what to do with the installed environment."
LangString C13_EXISTING_FOUND ${LANG_ENGLISH} "The installer detected an existing ${APP_NAME} installation in the selected folder."
LangString C13_EXISTING_REINSTALL ${LANG_ENGLISH} "Reinstall or update"
LangString C13_EXISTING_REINSTALL_DESC ${LANG_ENGLISH} "Continues to component selection. For existing folders you will be able to choose whether to keep them, refresh them, or preserve XAMPP data."
LangString C13_EXISTING_REPAIR ${LANG_ENGLISH} "Repair existing installation"
LangString C13_EXISTING_REPAIR_DESC ${LANG_ENGLISH} "Does not remove existing folders. Recreates shortcuts, registry entries and the uninstaller, and installs missing selected components."
LangString C13_EXISTING_REMOVE ${LANG_ENGLISH} "Remove ${APP_NAME}"
LangString C13_EXISTING_REMOVE_DESC ${LANG_ENGLISH} "Starts the uninstaller. During removal you can choose whether to keep downloaded archives and whether to remove the XAMPP folder with projects and databases."

LangString C13_EXISTING_COMPONENTS_TITLE ${LANG_ENGLISH} "Existing Components"
LangString C13_EXISTING_COMPONENTS_SUBTITLE ${LANG_ENGLISH} "Choose the data preservation strategy for folders found in the installation folder."
LangString C13_EXISTING_COMPONENTS_REPAIR_INFO ${LANG_ENGLISH} "In repair mode, existing folders will be preserved. Setup will recreate launchers, shortcuts, manifest, legal files and missing helper files."
LangString C13_EXISTING_COMPONENTS_INFO ${LANG_ENGLISH} "The installer detected existing folders. User data is preserved by default; no destructive option is selected."
LangString C13_EXISTING_VSCODE_REFRESH ${LANG_ENGLISH} "Refresh Visual Studio Code program files while preserving data\user-data and data\extensions:$\r$\n$INSTDIR\${VSCODE_INSTALL_DIR}"
LangString C13_EXISTING_VSCODE_DATA_REMOVE ${LANG_ENGLISH} "Remove preserved VS Code data and install cleanly:$\r$\n$INSTDIR\${VSCODE_INSTALL_DIR}\data"
LangString C13_EXISTING_XAMPP_REPAIR ${LANG_ENGLISH} "Repair existing XAMPP: preserve data, apply patches, run setup_xampp.bat and recreate shortcuts"
LangString C13_EXISTING_XAMPP_KEEP ${LANG_ENGLISH} "Keep existing XAMPP and verify control files"
LangString C13_EXISTING_XAMPP_REFRESH ${LANG_ENGLISH} "Refresh XAMPP program files: remove program files but preserve htdocs and mysql\data."
LangString C13_EXISTING_XAMPP_DATA_REFRESH ${LANG_ENGLISH} "Preserve htdocs and mysql\data and unpack a fresh XAMPP copy."
LangString C13_EXISTING_XAMPP_REMOVE ${LANG_ENGLISH} "Remove all of XAMPP and unpack a fresh copy (destructive)"
LangString C13_EXISTING_XAMPP_REMOVE_CONFIRM ${LANG_ENGLISH} "Full XAMPP folder removal has been selected.$\r$\n$\r$\nThis operation may remove htdocs and mysql\data. Continue?"

LangString C13_UNINSTALL_OPTIONS_TITLE ${LANG_ENGLISH} "Removal Options"
LangString C13_UNINSTALL_OPTIONS_SUBTITLE ${LANG_ENGLISH} "Setup removes program files, launchers and shortcuts. User data is preserved unless selected for removal."
LangString C13_UNINSTALL_OPTIONS_INFO ${LANG_ENGLISH} "Choose additional data to remove. Program files, launchers and shortcuts are removed automatically."
LangString C13_UNINSTALL_START_MENU ${LANG_ENGLISH} "Remove Start Menu shortcuts"
LangString C13_UNINSTALL_DESKTOP ${LANG_ENGLISH} "Remove desktop shortcuts created by Codex 13"
LangString C13_UNINSTALL_LAUNCHERS ${LANG_ENGLISH} "Remove Codex 13 launchers"
LangString C13_UNINSTALL_CACHE ${LANG_ENGLISH} "Remove downloaded archives/cache"
LangString C13_UNINSTALL_LOGS ${LANG_ENGLISH} "Remove installation logs"
LangString C13_UNINSTALL_VSCODE_DATA ${LANG_ENGLISH} "Remove portable VS Code configuration (data)"
LangString C13_UNINSTALL_XAMPP_HTDOCS ${LANG_ENGLISH} "Remove XAMPP htdocs data"
LangString C13_UNINSTALL_XAMPP_MYSQL ${LANG_ENGLISH} "Remove XAMPP mysql\data"
LangString C13_UNINSTALL_OPENSSH_KEYS ${LANG_ENGLISH} "Remove OpenSSH configuration and keys"
LangString C13_UNINSTALL_INSTALL_DIR ${LANG_ENGLISH} "Remove the entire installation folder:$\r$\n$INSTDIR"
LangString C13_UNINSTALL_INSTALL_DIR_CONFIRM ${LANG_ENGLISH} "The entire installation folder has been selected for removal.$\r$\n$\r$\nThis operation may remove projects, databases, VS Code configuration and SSH keys stored in this folder. Continue?"
LangString C13_UNINSTALL_MYSQL_CONFIRM ${LANG_ENGLISH} "XAMPP mysql\data has been selected for removal.$\r$\n$\r$\nThis may remove local databases. Continue?"
LangString C13_UNINSTALL_OPENSSH_CONFIRM ${LANG_ENGLISH} "OpenSSH configuration and keys have been selected for removal.$\r$\n$\r$\nPrivate keys may be required for repositories and servers. Continue?"

LangString DESC_SEC_VSCODE ${LANG_ENGLISH} "Portable Visual Studio Code ${VSCODE_VERSION}. The installer creates a Start Menu shortcut for the current user."
LangString DESC_SEC_XAMPP ${LANG_ENGLISH} "Portable XAMPP package with Apache, PHP, MariaDB and local server tools. Project and database data is protected during uninstall."
LangString DESC_SEC_GIT ${LANG_ENGLISH} "Portable Git for Windows ${GIT_VERSION}. The installer creates launchers for Git Bash and Git CMD."
LangString DESC_SEC_OPENSSH ${LANG_ENGLISH} "Portable OpenSSH for Windows ${OPENSSH_VERSION}. Useful for working with Git repositories over SSH."
LangString DESC_SEC_DESKTOP_SHORTCUTS ${LANG_ENGLISH} "Creates desktop shortcuts for installed tools."

