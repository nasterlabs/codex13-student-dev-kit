; Codex 13 Student Dev Kit — English UI strings.
; Included by Codex13StudentDevKit.nsi.

LangString C13_WELCOME_TITLE ${LANG_ENGLISH} "Welcome to Codex 13 Student Dev Kit Setup"
LangString C13_WELCOME_TEXT ${LANG_ENGLISH} "This wizard will prepare a portable Codex 13 development environment on this computer.$\r$\n$\r$\nThe environment can include a code editor, Git, a local web server, helper tools and launch shortcuts. Administrator privileges are not required if you choose a writable folder.$\r$\n$\r$\nClick Next to continue."
LangString C13_FINISH_TITLE ${LANG_ENGLISH} "Environment Ready"
LangString C13_FINISH_TEXT ${LANG_ENGLISH} "Codex 13 Student Dev Kit has been prepared.$\r$\n$\r$\nYou can now open Codex 13, open the installation folder, or close the wizard.$\r$\n$\r$\nInstalled components, licenses and the manifest are available in the installation folder."
LangString C13_FINISH_RUN ${LANG_ENGLISH} "Open Codex 13"
LangString C13_FINISH_OPEN_INSTALL_DIR ${LANG_ENGLISH} "Open installation folder"
LangString C13_SHORTCUT_OPEN_INSTALL_DIR ${LANG_ENGLISH} "Open Codex 13 Student Dev Kit installation folder"
LangString C13_SHORTCUT_UNINSTALL ${LANG_ENGLISH} "Uninstall Codex 13 Student Dev Kit"
LangString C13_SHORTCUT_OPEN_SITE ${LANG_ENGLISH} "Open Codex 13 website"
LangString C13_DIRECTORY_TEXT_TOP ${LANG_ENGLISH} "Choose the folder where the portable Codex 13 Student Dev Kit environment will be created.$\r$\n$\r$\nRecommended locations: a user folder under AppData\Local, a dedicated workspace folder, or another writable folder. Program Files and system folders are not recommended if the environment should work without administrator privileges.$\r$\n$\r$\nDownloaded package cache: packages in the installation folder."

LangString C13_TERMS_TITLE ${LANG_ENGLISH} "Terms and Privacy"
LangString C13_TERMS_SUBTITLE ${LANG_ENGLISH} "Read the short summary and confirm the required notices."
LangString C13_TERMS_ACCEPT_LICENSE ${LANG_ENGLISH} "I accept the Codex 13 Student Dev Kit license terms."
LangString C13_TERMS_ACCEPT_EXTERNAL ${LANG_ENGLISH} "I understand that the installer may download and configure external tools."
LangString C13_TERMS_ACCEPT_PRIVACY ${LANG_ENGLISH} "I have read the privacy and local diagnostic logs notice."

LangString C13_PROFILE_TITLE ${LANG_ENGLISH} "Choose Environment Profile"
LangString C13_PROFILE_SUBTITLE ${LANG_ENGLISH} "A profile describes the use case and selects a component set."
LangString C13_PROFILE_INTRO ${LANG_ENGLISH} "A profile answers the question: what should this environment be used for?"
LangString C13_PROFILE_START_DESC ${LANG_ENGLISH} "Learning, notes, Markdown and simple projects."
LangString C13_PROFILE_WEB_DESC ${LANG_ENGLISH} "JS/TS web applications."
LangString C13_PROFILE_FULLSTACK_DESC ${LANG_ENGLISH} "PHP/MySQL, XAMPP and mixed stacks. A good default profile."
LangString C13_PROFILE_CLASSROOM_DESC ${LANG_ENGLISH} "Classes, courses and computer labs."
LangString C13_PROFILE_CUSTOM_DESC ${LANG_ENGLISH} "Manual component and installation settings selection."
LangString C13_PLANNED ${LANG_ENGLISH} "(planned) "

LangString C13_PRESET_TITLE ${LANG_ENGLISH} "Choose Configuration Preset"
LangString C13_PRESET_SUBTITLE ${LANG_ENGLISH} "A preset defines starter settings, launchers and VS Code configuration."
LangString C13_SELECTED_PROFILE ${LANG_ENGLISH} "Selected profile:"
LangString C13_PRESET_CLEAN_VSCODE ${LANG_ENGLISH} "Clean VS Code"
LangString C13_PRESET_CLEAN_VSCODE_DESC ${LANG_ENGLISH} "Only portable Visual Studio Code and the base Setup elements."
LangString C13_PRESET_BASIC_DESC ${LANG_ENGLISH} "Minimal setup for notes, Markdown and lightweight projects."
LangString C13_PRESET_MARKDOWN_DESC ${LANG_ENGLISH} "Settings for Markdown, text files and note organization."
LangString C13_PRESET_FRONTEND_DESC ${LANG_ENGLISH} "Configuration for HTML, CSS, JavaScript, TypeScript, React and Vite."
LangString C13_PRESET_BACKEND_DESC ${LANG_ENGLISH} "Configuration for Node.js, npm/pnpm, APIs and backend projects."
LangString C13_PRESET_STATIC_DESC ${LANG_ENGLISH} "Configuration for static sites and simple frontend projects."
LangString C13_PRESET_PHP_MYSQL_DESC ${LANG_ENGLISH} "Configuration for XAMPP, Apache, PHP and MySQL."
LangString C13_PRESET_NODE_API_DESC ${LANG_ENGLISH} "Configuration for Node.js, APIs and JavaScript/TypeScript backends."
LangString C13_PRESET_MIXED_DESC ${LANG_ENGLISH} "Configuration for projects combining Node.js and XAMPP."
LangString C13_PRESET_INF03_DESC ${LANG_ENGLISH} "Configuration for classes on web application basics."
LangString C13_PRESET_CLASSROOM_PHP_DESC ${LANG_ENGLISH} "Configuration for PHP, forms, databases and XAMPP classes."
LangString C13_PRESET_CLASSROOM_NODE_DESC ${LANG_ENGLISH} "Configuration for Node.js/API backend classes."
LangString C13_PRESET_MANUAL_DESC ${LANG_ENGLISH} "Manual component configuration."
LangString C13_PRESET_LAUNCHER_INFO ${LANG_ENGLISH} "Note: VS Code will be started through the Codex 13 launcher, which automatically adds tools installed in this environment to PATH."
LangString C13_PRESET_PLANNED_CLEAN ${LANG_ENGLISH} "This preset is still planned.$\r$\nSetup will return to the active preset: Clean VS Code."
LangString C13_PRESET_PLANNED_PHP ${LANG_ENGLISH} "This preset is still planned.$\r$\nSetup will return to the active preset: PHP + MySQL."

LangString C13_COMPONENTS_TITLE ${LANG_ENGLISH} "Choose Components"
LangString C13_COMPONENTS_SUBTITLE ${LANG_ENGLISH} "The profile and preset selected a default component set. You can adjust it before installation."
LangString C13_COMPONENTS_START_MENU_AUTO ${LANG_ENGLISH} "The Start Menu folder will be created automatically."
LangString C13_COMPONENTS_REQUIRED ${LANG_ENGLISH} "Required"
LangString C13_COMPONENTS_LEGAL ${LANG_ENGLISH} "✓ Legal files, manifest and logs"
LangString C13_COMPONENTS_TOOLS ${LANG_ENGLISH} "Tools"
LangString C13_COMPONENTS_RUNTIME ${LANG_ENGLISH} "Servers and runtime"
LangString C13_COMPONENTS_NODE_PLANNED ${LANG_ENGLISH} "Portable Node.js will be available in the next version."
LangString C13_COMPONENTS_DESCRIPTION ${LANG_ENGLISH} "Component description"
LangString C13_COMPONENTS_DESKTOP ${LANG_ENGLISH} "Desktop shortcuts"
LangString C13_COMPONENTS_NO_MAIN_TOOLS ${LANG_ENGLISH} "All main tools have been unchecked.$\r$\n$\r$\nSetup will create only the base structure, launchers, legal files, manifest and logs. Continue?"
LangString C13_COMPONENTS_NO_GIT ${LANG_ENGLISH} "Git for Windows is important for most Codex 13 scenarios.$\r$\n$\r$\nYou can continue without Git, but some workflows may require manual configuration. Continue?"

LangString C13_DIR_PROGRAM_FILES_WARNING ${LANG_ENGLISH} "The selected folder is inside Program Files.$\r$\n$\r$\nThe portable environment may require administrator privileges to write there. You can continue knowingly or go back and choose a user folder."
LangString C13_DIR_WINDOWS_WARNING ${LANG_ENGLISH} "The selected folder is inside the Windows system directory.$\r$\n$\r$\nThis is not recommended for a portable environment. You can continue knowingly or go back and choose a user folder."
LangString C13_DIR_CREATE_FAILED ${LANG_ENGLISH} "Cannot create the installation folder:$\r$\n$INSTDIR$\r$\n$\r$\nChoose a folder where you have write permissions."

