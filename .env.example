NSIS_PATH=C:\Tools\nsis\makensis.exe

# Local env files contain machine-specific paths and secrets.
# Never commit .env, .env.dev, or .env.prod. Commit only *.example templates.

# Debug log written next to the installer EXE during a run. Off by default.
# C13_DEBUG_LOG_ENABLED=1
# C13_DEBUG_LOG_FILE=$EXEDIR\c13sdk-debug.log

# Build channel controls output name and VersionInfo.
# dev     -> dist\setup\Codex13SDK-Setup-dev.exe
# release -> dist\setup\Codex13SDK-Setup.exe
# BUILD_VERSION is normally derived from APP_VERSION in apps/setup/src/nsis/config.nsh.
# If overridden, it must keep the same SemVer core as APP_VERSION.
# First public builds use 0.7.0-alpha.<build_number>.
BUILD_CHANNEL=dev
# BUILD_VERSION=0.7.0-alpha.local

# Optional local development signing.
# Run tools\dev\setup-dev-cert.ps1 to generate and trust a local dev certificate,
# then use the generated certificate thumbprint in your local env file.
SIGNING_ENABLED=0

# Certificate store mode (CurrentUser\My)
# SIGN_CERT_THUMBPRINT=

# Optional. If omitted, DigiCert timestamping is used.
SIGN_TIMESTAMP_URL=http://timestamp.digicert.com
# SIGNTOOL_PATH=C:\Program Files (x86)\Windows Kits\10\bin\...\x64\signtool.exe
