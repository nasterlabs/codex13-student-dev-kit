NSIS_PATH=C:\Tools\nsis\makensis.exe

# Local env files contain machine-specific paths and secrets.
# Never commit .env.prod. Commit only this template.

BUILD_CHANNEL=release

# BUILD_VERSION is optional for local release builds. If omitted, the build
# script uses 0.7.0-alpha.local. Public release builds must set a numeric
# alpha suffix, e.g. 0.7.0-alpha.<build_number>.
# BUILD_VERSION=0.7.0-alpha.<build_number>

# Debug log disabled in production builds.
# C13_DEBUG_LOG_ENABLED=1

# Code signing is disabled for the first unsigned alpha releases.
# Enable only after production Authenticode signing is configured.
SIGNING_ENABLED=0
# Certificate store mode (CurrentUser\My)
# SIGN_CERT_THUMBPRINT=
SIGN_TIMESTAMP_URL=http://timestamp.digicert.com
